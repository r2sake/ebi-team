# ============================================================
# ebi-team 環境変数サンプル
# ------------------------------------------------------------
# 使い方:
#   cp .env.sample .env      # このファイルをコピーして
#   （必要な行のコメント # を外して値を設定）
#   npm start                # 起動時にリポジトリルートの .env を自動読み込み
#
# precedence: 実際の環境変数が .env より優先されます。
#   例) EBI_PORT=9000 npm start は .env の EBI_PORT より優先
#
# ここに書かれた値はすべて「既定値」です。既定のままでよいキーは
# 設定不要（行ごと消しても / コメントアウトのままでも動きます）。
# ============================================================

# ── アクセス認証（スマホ / LAN外アクセス用）───────────────
# 非 loopback（Tailscale 等の外部）からのアクセスに要求する共有トークン。
# 未設定のまま非 loopback に bind すると外部アクセスは全拒否（安全側デフォルト）。
# loopback（localhost）からは常に無認証で通るため、母艦ローカル利用には不要。
# トークン生成（十分に強い 64 文字が 1 個出る）:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#EBI_AUTH_TOKEN=

# ── ネットワーク（bind 先）─────────────────────────────
# 待受ホスト。既定は 127.0.0.1（loopback 限定＝ローカルのみ）。
# スマホから使うなら Tailscale の IP（100.x.y.z）を推奨。0.0.0.0 は全 IF 公開（要トークン）。
#EBI_HOST=127.0.0.1
# 待受ポート。スマホ側のアクセス URL もこのポートに合わせること。
#EBI_PORT=8787

# ── エビ（Claude Code セッション）の起動設定 ─────────────
# spawn するコマンド。claude が PATH に無い環境では bash 等で fallback 可。
#EBI_COMMAND=claude
# 上記コマンドへ渡す追加引数（スペース区切り）。
#EBI_ARGS=
# エビの既定作業ディレクトリ。未設定ならサーバ起動時の cwd。
#EBI_DEFAULT_CWD=/path/to/your/project

# ── md/txt ビューア ────────────────────────────────────
# ビューアで開ける許可ルート（":" 区切り・~ / $HOME 展開可）。既定は $HOME/workspace。
#EBI_VIEWER_ROOTS=$HOME/workspace
# ビューアで開けるファイルサイズ上限（バイト）。既定 1MB。
#EBI_VIEWER_MAX_BYTES=1048576

# ── 各種タイムアウト / しきい値（通常は既定のままで可）──────
# 出力がこの時間(ms)止まったら idle とみなす。
#EBI_IDLE_MS=900
# send_message が ready（入力受付）になるまで待つ最大時間(ms)。
#EBI_READY_WAIT_MS=30000
# notification 経路の購読確立を待つ最大時間(ms)。超えたら PTY 注入へフォールバック。
#EBI_SUBSCRIBE_WAIT_MS=20000
# 再アタッチ用スクロールバックのリングバッファ上限(バイト)。既定 256KB。
#EBI_SCROLLBACK_BYTES=262144

# ── ファイル配置（通常は既定のままで可）────────────────────
# registry のダンプ先。既定は <cwd>/.ebi-team/registry.json。
#EBI_DUMP_PATH=
# 固定エビ config のパス。既定は <cwd>/ebi-team.config.json（無ければ固定エビ機能 OFF）。
#EBI_CONFIG_PATH=

# ── 高度な設定（内部・特殊用途）──────────────────────────
# idle 通知の ON/OFF。npm start / npm run dev では off が渡されます。
#EBI_IDLE_NOTIFY=on
# master→エビ の送信注入モード。"pty" or "notify"（既定 notify）。
#EBI_INJECT_MODE=notify
# 監督（要約）機能のコマンド上書き。
#EBI_SUMMARY_CMD=
